# DeepSeek（OpenAI 兼容）— 复制为 .env，勿提交 Git
DEEPSEEK_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
ENABLE_LLM_SUMMARY=true
LLM_MAX_RULES_PER_RUN=20
LLM_CONTENT_MAX_CHARS=6000
LLM_REQUEST_DELAY_MS=500

# 分类页引用来源自动同步卡片
ENABLE_CURATED_AUTO_PUBLISH=true
LLM_MAX_CURATED_SOURCES_PER_RUN=2
# NOTIFY_WEBHOOK_URL=https://your-webhook-for-dingtalk-or-wecom
