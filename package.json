{
  "name": "tmall-rule-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "autostart:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-autostart.ps1",
    "autostart:remove": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-autostart.ps1",
    "migrate:urls": "node scripts/migrate-rule-urls.mjs",
    "crawl": "node scripts/gh-crawl.mjs",
    "crawl:intl": "node scripts/gh-crawl.mjs --platform=intl",
    "summarize": "node scripts/summarize-rules.mjs",
    "migrate:curated": "node scripts/migrate-curated-data.mjs",
    "migrate:score-insights": "node scripts/migrate-score-insights.mjs",
    "sync:curated": "node scripts/sync-curated-cards.mjs",
    "sync:curated:intl": "node scripts/sync-curated-cards.mjs --platform=intl --force-source=intl-rule-11005234",
    "audit:fabrication": "node scripts/audit-curated-fabrication.mjs"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "cheerio": "^1.1.2",
    "dayjs": "^1.11.18",
    "express": "^4.21.2",
    "node-cron": "^4.2.1",
    "xlsx": "^0.18.5"
  }
}
